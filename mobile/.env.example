# Point the app at your backend. On a physical phone, localhost is the PHONE,
# not your PC — use your computer's LAN IP (find it with `ipconfig`).
#
#   EXPO_PUBLIC_API_BASE=http://192.168.1.20:8080
#   EXPO_PUBLIC_WS_BASE=ws://192.168.1.20:8080
#
# On the Android emulator use 10.0.2.2; on the iOS simulator localhost works.

EXPO_PUBLIC_API_BASE=http://localhost:8080
EXPO_PUBLIC_WS_BASE=ws://localhost:8080
